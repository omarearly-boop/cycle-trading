//@version=5
indicator("Cycles Trading Levels — All Setups", overlay=true, max_lines_count=500)
// ─── HOW TO USE ───────────────────────────────────────────
// 1. Open the chart for any stock/coin below (Weekly 1W)
// 2. Click Pine Editor at the bottom
// 3. Paste this entire script -> click "Add to chart"
// 4. Lines for that ticker appear automatically

ticker = syminfo.ticker

// ▲ ADI
if str.contains(syminfo.ticker, "ADI")
    line.new(bar_index-50, 389.58, bar_index+20, 389.58, color=color.blue,  width=2)
    line.new(bar_index-50, 369.78,  bar_index+20, 369.78,  color=color.red,   width=2, style=line.style_dashed)
    line.new(bar_index-50, 508.1,bar_index+20, 508.1,color=color.green, width=2, style=line.style_dashed)
    line.new(bar_index-50, 581.3454,    bar_index+20, 581.3454,    color=color.green, width=1, style=line.style_dotted)
    line.new(bar_index-50, 699.8654,    bar_index+20, 699.8654,    color=color.green, width=1, style=line.style_dotted)
    label.new(bar_index+1, 389.58,  "Entry $389.58",  color=color.blue,  textcolor=color.white, style=label.style_label_left)
    label.new(bar_index+1, 369.78,   "Stop  $369.78",   color=color.red,   textcolor=color.white, style=label.style_label_left)
    label.new(bar_index+1, 508.1, "T1    $508.1", color=color.green, textcolor=color.white, style=label.style_label_left)
    label.new(bar_index+1, 581.3454,     "T2    $581.3454",     color=color.green, textcolor=color.white, style=label.style_label_left)
    label.new(bar_index+1, 699.8654,     "T3    $699.8654",     color=color.green, textcolor=color.white, style=label.style_label_left)

