//@version=5
indicator("Cycles Trading Levels — All Setups", overlay=true, max_lines_count=500)
// ─── HOW TO USE ───────────────────────────────────────────
// 1. Open the chart for any stock/coin below (Weekly 1W)
// 2. Click Pine Editor at the bottom
// 3. Paste this entire script -> click "Add to chart"
// 4. Lines for that ticker appear automatically

ticker = syminfo.ticker

// ▼ GTLB
if str.contains(syminfo.ticker, "GTLB")
    line.new(bar_index-50, 32.85, bar_index+20, 32.85, color=color.blue,  width=2)
    line.new(bar_index-50, 35.08,  bar_index+20, 35.08,  color=color.red,   width=2, style=line.style_dashed)
    line.new(bar_index-50, 18.73,bar_index+20, 18.73,color=color.green, width=2, style=line.style_dashed)
    line.new(bar_index-50, 10.0038,    bar_index+20, 10.0038,    color=color.green, width=1, style=line.style_dotted)
    line.new(bar_index-50, -4.1162,    bar_index+20, -4.1162,    color=color.green, width=1, style=line.style_dotted)
    label.new(bar_index+1, 32.85,  "Entry $32.85",  color=color.blue,  textcolor=color.white, style=label.style_label_left)
    label.new(bar_index+1, 35.08,   "Stop  $35.08",   color=color.red,   textcolor=color.white, style=label.style_label_left)
    label.new(bar_index+1, 18.73, "T1    $18.73", color=color.green, textcolor=color.white, style=label.style_label_left)
    label.new(bar_index+1, 10.0038,     "T2    $10.0038",     color=color.green, textcolor=color.white, style=label.style_label_left)
    label.new(bar_index+1, -4.1162,     "T3    $-4.1162",     color=color.green, textcolor=color.white, style=label.style_label_left)

